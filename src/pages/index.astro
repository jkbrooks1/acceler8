---
import Base from '../layouts/Base.astro';

declare global {
  interface Window {
    scrollToSection: (id: string) => void;
  }
}

const STOCK_IMAGES = {
  heroAtmosphere: {
    filename: '015.a8Stock.GRAPHIC-ELEMENTS.jpg',
    src: 'https://pub-906aebdaaf22471faa576c94c2cdf07b.r2.dev/015.a8Stock.GRAPHIC-ELEMENTS.jpg',
  },
  workflowSystems: {
    filename: '009.a8Stock.SYSTEMS.jpg',
    src: 'https://pub-906aebdaaf22471faa576c94c2cdf07b.r2.dev/009.a8Stock.SYSTEMS.jpg',
  },
  processSystems: {
    filename: '007.a8Stock.SYSTEMS.jpg',
    src: 'https://pub-906aebdaaf22471faa576c94c2cdf07b.r2.dev/007.a8Stock.SYSTEMS.jpg',
  },
  partnershipTeams: {
    filename: '013.a8Stock.TEAMS.jpg',
    src: 'https://pub-906aebdaaf22471faa576c94c2cdf07b.r2.dev/013.a8Stock.TEAMS.jpg',
  },
  revenueOutcomes: {
    filename: '006.a8Stock.REVENUE.jpg',
    src: 'https://pub-906aebdaaf22471faa576c94c2cdf07b.r2.dev/006.a8Stock.REVENUE.jpg',
  },
  insightsDataViz: {
    filename: '004.a8Stock.DATA-VIZ.jpg',
    src: 'https://pub-906aebdaaf22471faa576c94c2cdf07b.r2.dev/004.a8Stock.DATA-VIZ.jpg',
  },
  closingTexture: {
    filename: '017.a8Stock.GRAPHIC-ELEMENTS.jpg',
    src: 'https://pub-906aebdaaf22471faa576c94c2cdf07b.r2.dev/017.a8Stock.GRAPHIC-ELEMENTS.jpg',
  },
} as const;
---

<Base>
  <!-- Navigation -->
  <nav class="navbar">
    <div class="navbar-container">
      <div class="navbar-logo">
        <img src="/assets/logos/v2_Acceler8_Logo_Company.png" alt="Acceler8-ai" class="navbar-logo-img">
      </div>
      <ul class="nav-menu">
        <li><a href="#problems">Workflow Problems</a></li>
        <li><a href="#how-we-work">How We Work</a></li>
        <li><a href="#network">Our Network</a></li>
        <li><a href="#insights">Insights</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
      <button class="nav-cta" onclick="window.location.href='mailto:connect@acceler8-ai.com'">Start a Review</button>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="hero visual-section visual-section--hero">
    <img class="visual-section__media" src={STOCK_IMAGES.heroAtmosphere.src} alt="" aria-hidden="true" loading="eager" decoding="async">
    <div class="visual-section__overlay visual-section__overlay--hero"></div>
    <div class="hero-container hero-shell">
      <div class="hero-content scroll-fade-in">
        <p class="eyebrow">Acceler8-ai</p>
        <h1 class="hero-headline">Picking the right workflow tech is hard . . . and it matters</h1>
        <p class="hero-subtitle">Our clients get the right n8n tech and delivery to solve workflow problems that move the cashflow needle.</p>
        <div class="hero-buttons">
          <button class="btn btn-primary" onclick="window.location.href='mailto:connect@acceler8-ai.com'">Connect with Acceler8!</button>
          <button class="btn btn-secondary" onclick="scrollToSection('how-we-work')">See How We Work</button>
        </div>
      </div>
      <div class="hero-visual scroll-fade-in">
        <div class="workflow-panel hero-panel">
          <p class="panel-kicker">Workflow focus</p>
          <div class="hero-panel-grid">
            <div class="panel-card">
              <div class="service-number">1</div>
              <h3>Select</h3>
              <p>Match the problem to the right tools.</p>
            </div>
            <div class="panel-card">
              <div class="service-number">2</div>
              <h3>Deploy</h3>
              <p>Put the system into motion cleanly.</p>
            </div>
            <div class="panel-card">
              <div class="service-number">3</div>
              <h3>Connect</h3>
              <p>Turn point solutions into working systems.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Workflow Problems Section -->
  <section id="problems" class="problem-section visual-section visual-section--dark scroll-fade-in">
    <img class="visual-section__media" src={STOCK_IMAGES.workflowSystems.src} alt="" aria-hidden="true" loading="lazy" decoding="async">
    <div class="visual-section__overlay visual-section__overlay--dark"></div>
    <div class="container">
      <div class="section-intro">
        <p class="eyebrow">Workflow problems</p>
      <h2 class="section-title">Workflow problems where speed and reliability drive revenue.</h2>
        <p class="section-subtitle">Most teams do not need more software. They need the right tools working together.</p>
      </div>
      <div class="cards-grid stagger-children">
        <div class="card">
          <div class="card-icon">💵</div>
          <h3>Invoice Creation & Collection</h3>
          <p>Delayed invoicing extends your cash cycle. Manual processes create errors and delays. Automated, reliable billing moves cash faster.</p>
        </div>
        <div class="card">
          <div class="card-icon">⚡</div>
          <h3>Sales Cycle Time</h3>
          <p>Manual follow-up slows deals. Fragmented systems mean lost leads. Connected workflows keep deals moving and opportunities visible.</p>
        </div>
        <div class="card">
          <div class="card-icon">📞</div>
          <h3>AR Follow-Up & Retention</h3>
          <p>Chasing payments and keeping customers engaged requires coordination across teams. Automated workflows ensure nothing falls through the cracks.</p>
        </div>
        <div class="card">
          <div class="card-icon">💼</div>
          <h3>Scaling Without Headcount</h3>
          <p>Growth requires operations to scale faster than your team. Workflow automation lets you grow revenue without proportional cost increases.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How We Work Section -->
  <section id="how-we-work" class="services-section visual-section visual-section--light scroll-fade-in">
    <img class="visual-section__media" src={STOCK_IMAGES.processSystems.src} alt="" aria-hidden="true" loading="lazy" decoding="async">
    <div class="visual-section__overlay visual-section__overlay--light"></div>
    <div class="container">
      <div class="section-intro section-intro--dark">
        <p class="eyebrow">How we work</p>
        <h2 class="section-title">A practical partner for technology selection, deployment, and connection.</h2>
        <p class="section-subtitle">We know the n8n ecosystem and we recommend technologies and partners that actually fit the problem.</p>
      </div>
      <div class="cards-grid cards-3col stagger-children">
        <div class="card card-service">
          <div class="service-number">1</div>
          <h3>Identify</h3>
          <p>We listen. What workflow problems are costing you revenue or operational efficiency? We focus on the high-impact ones: the problems that move the needle.</p>
        </div>
        <div class="card card-service">
          <div class="service-number">2</div>
          <h3>Recommend</h3>
          <p>We know the n8n ecosystem. We recommend n8n-compatible technologies and vetted partners that solve your specific problem. Our opinion comes first, always.</p>
        </div>
        <div class="card card-service">
          <div class="service-number">3</div>
          <h3>Connect</h3>
          <p>We connect you with implementers—either our services or trusted partners. We handle deployment, adoption, and handoff so you operate the solution successfully.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Network Section -->
  <section id="network" class="network-section visual-section visual-section--teal scroll-fade-in">
    <img class="visual-section__media" src={STOCK_IMAGES.partnershipTeams.src} alt="" aria-hidden="true" loading="lazy" decoding="async">
    <div class="visual-section__overlay visual-section__overlay--teal"></div>
    <div class="container">
      <div class="section-intro">
        <p class="eyebrow">Our network</p>
        <h2 class="section-title">Our network: vendors and implementers.</h2>
        <p class="section-subtitle">We maintain relationships with technology vendors and specialized implementers across the n8n ecosystem.</p>
      </div>
      <div class="network-grid">
        <div class="network-card">
          <h3>Vendor fit</h3>
          <p>We help identify the right platform or product before the team commits time or budget.</p>
        </div>
        <div class="network-card">
          <h3>Implementation support</h3>
          <p>We connect clients with the people who can actually deliver the system cleanly.</p>
        </div>
        <div class="network-card">
          <h3>Partner alignment</h3>
          <p>We keep the recommendation honest and aligned to the business outcome.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Acceler8-ai Section -->
  <section class="why-section visual-section visual-section--warm scroll-fade-in">
    <img class="visual-section__media" src={STOCK_IMAGES.revenueOutcomes.src} alt="" aria-hidden="true" loading="lazy" decoding="async">
    <div class="visual-section__overlay visual-section__overlay--warm"></div>
    <div class="container">
      <div class="section-intro">
        <p class="eyebrow">Why Acceler8-ai?</p>
        <h2 class="section-title">Why Acceler8-ai?</h2>
        <p class="section-subtitle">We focus on workflow problems that move cash, not nice-to-have optimizations.</p>
      </div>
      <div class="cards-grid stagger-children">
        <div class="card">
          <div class="card-icon">🎯</div>
          <h3>We Know What Drives Revenue</h3>
          <p>We focus on workflow problems that move cash, not nice-to-have optimizations. Every recommendation ties to revenue or operational impact.</p>
        </div>
        <div class="card">
          <div class="card-icon">🤝</div>
          <h3>Your Opinion Comes First</h3>
          <p>We represent technology partners, but our opinion on what's right for your business always comes first. We're incentivized by your success.</p>
        </div>
        <div class="card">
          <div class="card-icon">🌐</div>
          <h3>Network of Experts</h3>
          <p>We match you with implementers who specialize in your specific problem. Whether n8n developers, RevOps experts, or finance operations specialists—we know them.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Insights Strip -->
  <section id="insights" class="positioning-strip visual-section visual-section--navy scroll-fade-in">
    <img class="visual-section__media" src={STOCK_IMAGES.insightsDataViz.src} alt="" aria-hidden="true" loading="lazy" decoding="async">
    <div class="visual-section__overlay visual-section__overlay--navy"></div>
    <div class="container">
      <div class="section-intro section-intro--light">
        <p class="eyebrow">Insights</p>
        <h2 class="section-title">Workflow problems that move cash. Measured, connected, and visible.</h2>
        <p class="section-subtitle">Dashboards and clear handoffs make the impact of the workflow visible enough to improve it.</p>
      </div>
      <div class="metrics-grid">
        <div class="metric-card">
          <strong>Faster</strong>
          <span>sales and service handoffs</span>
        </div>
        <div class="metric-card">
          <strong>Clearer</strong>
          <span>operational visibility</span>
        </div>
        <div class="metric-card">
          <strong>Better</strong>
          <span>workflow decisions</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="closing-cta visual-section visual-section--cta scroll-fade-in">
    <img class="visual-section__media" src={STOCK_IMAGES.closingTexture.src} alt="" aria-hidden="true" loading="lazy" decoding="async">
    <div class="visual-section__overlay visual-section__overlay--cta"></div>
    <div class="container">
      <div class="cta-panel">
        <p class="eyebrow">Ready to connect</p>
        <h2 class="section-title">Time to get to work?</h2>
        <p class="section-subtitle">Start a Technology Fit Review and get the right next step for your workflow.</p>
        <button class="btn btn-primary btn-large" onclick="window.location.href='mailto:connect@acceler8-ai.com'">Connect with Acceler8!</button>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer id="contact" class="footer">
    <div class="footer-container">
      <div class="footer-section">
        <h3>Acceler8-ai</h3>
        <p>Technology selection, deployment, and operations for B2B workflow problems that move cash.</p>
      </div>
      <div class="footer-section footer-contact">
        <p><a href="mailto:connect@acceler8-ai.com">connect@acceler8-ai.com</a></p>
        <p><a href="tel:206-970-6240">206-970-6240</a></p>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 Acceler8-ai. All rights reserved.</p>
    </div>
  </footer>

  <style>
    .positioning-strip {
      background-color: var(--color-systems-navy);
      color: var(--text-light);
      padding: 2rem 0;
    }

    .positioning-text {
      text-align: center;
      font-size: 1.25rem;
      font-weight: 600;
      margin: 0;
      line-height: 1.5;
      color: var(--text-light);
    }

    .closing-cta {
      text-align: center;
      padding: 2.5rem 0;
    }

    .closing-cta .btn {
      margin-top: var(--space-xl);
    }

    .problem-section,
    .services-section,
    .network-section,
    .why-section,
    .closing-cta {
      background-color: var(--bg-primary);
    }

    .hero {
      padding: 3rem 0;
      background-color: var(--bg-primary);
      position: relative;
      overflow: hidden;
    }

    .hero-container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 var(--space-lg);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
    }

    .hero-content {
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .hero-headline {
      color: var(--text-primary);
      margin-bottom: var(--space-lg);
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 700;
      line-height: 1.2;
    }

    .hero-subtitle {
      font-size: 1.1rem;
      color: var(--text-secondary);
      margin-bottom: var(--space-2xl);
      line-height: 1.8;
    }

    .hero-visual {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .workflow-panel {
      background: linear-gradient(135deg, rgba(37, 99, 235, 0.05) 0%, rgba(47, 125, 122, 0.05) 100%);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-xl);
      padding: 2.5rem;
      box-shadow: var(--shadow-md);
      width: 100%;
    }

    .flow-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .flow-step {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-sm);
      flex: 1;
      min-width: 100px;
    }

    .flow-icon {
      font-size: 2.5rem;
      display: block;
    }

    .flow-label {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--text-primary);
      margin: 0;
      text-align: center;
    }

    .flow-arrow {
      color: var(--accent-secondary);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .flow-arrow svg {
      stroke: var(--accent-secondary);
    }

    @media (max-width: 1024px) {
      .hero-container {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      .workflow-panel {
        padding: 1.5rem;
      }

      .flow-row {
        gap: 0.5rem;
      }

      .flow-step {
        min-width: 80px;
      }

      .flow-icon {
        font-size: 2rem;
      }

      .flow-label {
        font-size: 0.75rem;
      }
    }

    @media (max-width: 640px) {
      .hero {
        padding: 3rem 0;
      }

      .hero-headline {
        font-size: 1.75rem;
      }

      .hero-subtitle {
        font-size: 1rem;
      }

      .flow-row {
        flex-direction: column;
        gap: 1rem;
      }

      .flow-step {
        min-width: 100%;
      }

      .flow-arrow {
        transform: rotate(90deg);
      }

      .workflow-panel {
        padding: 1rem;
      }
    }

    .visual-section {
      position: relative;
      overflow: hidden;
      isolation: isolate;
    }

    .visual-section__media {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: -2;
    }

    .visual-section__overlay {
      position: absolute;
      inset: 0;
      z-index: -1;
    }

    .visual-section__overlay--hero {
      background: linear-gradient(120deg, rgba(22, 36, 58, 0.9) 0%, rgba(22, 36, 58, 0.7) 48%, rgba(22, 36, 58, 0.25) 100%);
    }

    .visual-section__overlay--dark {
      background: linear-gradient(120deg, rgba(22, 36, 58, 0.92) 0%, rgba(22, 36, 58, 0.72) 100%);
    }

    .visual-section__overlay--light {
      background: linear-gradient(120deg, rgba(247, 243, 234, 0.9) 0%, rgba(247, 243, 234, 0.74) 100%);
    }

    .visual-section__overlay--teal {
      background: linear-gradient(120deg, rgba(22, 36, 58, 0.9) 0%, rgba(47, 125, 122, 0.58) 100%);
    }

    .visual-section__overlay--warm {
      background: linear-gradient(120deg, rgba(22, 36, 58, 0.88) 0%, rgba(182, 106, 58, 0.45) 100%);
    }

    .visual-section__overlay--navy {
      background: linear-gradient(120deg, rgba(16, 24, 40, 0.94) 0%, rgba(22, 36, 58, 0.74) 100%);
    }

    .visual-section__overlay--cta {
      background: linear-gradient(120deg, rgba(22, 36, 58, 0.92) 0%, rgba(22, 36, 58, 0.7) 100%);
    }

    .hero.visual-section--hero {
      min-height: calc(100vh - 88px);
      padding: 0;
      display: flex;
      align-items: center;
    }

    .visual-section > .container {
      position: relative;
      z-index: 1;
      padding-top: var(--space-4xl);
      padding-bottom: var(--space-4xl);
    }

    .eyebrow {
      margin-bottom: var(--space-sm);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 0.75rem;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.85);
    }

    .section-intro {
      display: grid;
      gap: var(--space-sm);
      max-width: 70ch;
      margin-bottom: var(--space-2xl);
    }

    .section-intro .section-title {
      color: var(--text-light);
      font-size: clamp(1.9rem, 4vw, 3.25rem);
      line-height: 1.08;
      margin-bottom: 0;
    }

    .section-intro .section-subtitle {
      color: rgba(255, 255, 255, 0.86);
      margin: 0;
      font-size: 1.05rem;
      max-width: 58ch;
    }

    .section-intro--dark .section-title,
    .section-intro--dark .section-subtitle,
    .section-intro--dark .eyebrow {
      color: var(--text-primary);
    }

    .section-intro--dark .section-subtitle {
      color: var(--text-secondary);
    }

    .section-intro--light .section-title,
    .section-intro--light .section-subtitle,
    .section-intro--light .eyebrow {
      color: var(--text-light);
    }

    .hero-shell {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
      gap: var(--space-2xl);
      align-items: center;
      width: 100%;
      padding-top: var(--space-4xl);
      padding-bottom: var(--space-4xl);
      position: relative;
      z-index: 1;
    }

    .hero-panel {
      width: 100%;
      padding: var(--space-xl);
      background: rgba(247, 243, 234, 0.94);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-lg);
      backdrop-filter: blur(12px);
    }

    .panel-kicker {
      margin-bottom: var(--space-lg);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--accent-primary);
    }

    .hero-panel-grid {
      display: grid;
      gap: var(--space-md);
    }

    .panel-card {
      padding: var(--space-lg);
      border-radius: var(--radius-lg);
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(30, 37, 40, 0.08);
    }

    .panel-card h3 {
      margin-bottom: var(--space-sm);
    }

    .panel-card p {
      margin: 0;
      color: var(--text-secondary);
    }

    .network-grid,
    .metrics-grid {
      display: grid;
      gap: var(--space-lg);
    }

    .network-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .network-card,
    .metric-card {
      padding: var(--space-xl);
      border-radius: var(--radius-lg);
      background: rgba(247, 243, 234, 0.92);
      border: 1px solid rgba(30, 37, 40, 0.08);
      box-shadow: var(--shadow-md);
    }

    .network-card h3 {
      margin-bottom: var(--space-sm);
      color: var(--text-primary);
    }

    .network-card p,
    .metric-card span {
      margin: 0;
      color: var(--text-secondary);
    }

    .metrics-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .metric-card {
      display: grid;
      gap: var(--space-xs);
      min-height: 120px;
      align-content: center;
    }

    .metric-card strong {
      color: var(--text-primary);
      font-size: clamp(1.5rem, 4vw, 2rem);
      line-height: 1;
    }

    .cta-panel {
      max-width: 760px;
      width: 100%;
      padding: clamp(1.5rem, 4vw, 3rem);
      background: rgba(22, 36, 58, 0.7);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: var(--radius-xl);
      color: var(--text-light);
      box-shadow: var(--shadow-lg);
      backdrop-filter: blur(12px);
      text-align: center;
    }

    .cta-panel .section-title,
    .cta-panel .section-subtitle,
    .cta-panel .eyebrow {
      color: var(--text-light);
      max-width: none;
    }

    .cta-panel .btn {
      margin-top: var(--space-xl);
    }

    .section-intro .section-title,
    .section-intro .section-subtitle {
      max-width: none;
    }

    .visual-section--hero .hero-headline,
    .visual-section--hero .hero-subtitle {
      color: var(--text-light);
    }

    .visual-section--hero .hero-buttons .btn-secondary {
      color: var(--text-light);
      border-color: rgba(255, 255, 255, 0.6);
    }

    .visual-section--hero .hero-buttons .btn-secondary:hover {
      background-color: rgba(255, 255, 255, 0.12);
      color: var(--text-light);
    }

    .visual-section--dark .card,
    .visual-section--light .card,
    .visual-section--teal .card,
    .visual-section--warm .card,
    .visual-section--navy .card {
      background: rgba(247, 243, 234, 0.92);
      backdrop-filter: blur(12px);
    }

    @media (max-width: 1024px) {
      .hero-shell,
      .network-grid,
      .metrics-grid {
        grid-template-columns: 1fr;
      }

      .hero-shell {
        gap: var(--space-xl);
      }
    }

    @media (max-width: 768px) {
      .hero.visual-section--hero {
        min-height: auto;
      }

      .visual-section > .container,
      .hero-shell {
        padding-top: var(--space-3xl);
        padding-bottom: var(--space-3xl);
      }

      .hero-buttons {
        flex-direction: column;
      }

      .hero-buttons .btn {
        width: 100%;
      }

      .network-grid,
      .metrics-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    function scrollToSection(id: string) {
      const element = document.getElementById(id);
      if (element) {
        element.scrollIntoView({ behavior: 'smooth' });
      }
    }
    window.scrollToSection = scrollToSection;

    // Intersection Observer for scroll animations
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    document.querySelectorAll('.scroll-fade-in, .scroll-slide-left, .scroll-slide-right').forEach(el => {
      observer.observe(el);
    });

    // Stagger animations for cards
    document.querySelectorAll('.stagger-children').forEach(container => {
      const children = container.querySelectorAll(':scope > *');
      children.forEach((child, index) => {
        if (child instanceof HTMLElement) {
          child.style.animation = `fadeInUp 0.6s ease-out ${index * 0.1 + 0.2}s backwards`;
        }
      });
    });
  </script>
</Base>
