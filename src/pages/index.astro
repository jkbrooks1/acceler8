---
import Base from '../layouts/Base.astro';
import { landingCopy } from '../data/a8LandingCopy';

declare global {
  interface Window {
    scrollToSection: (id: string) => void;
  }
}

const STOCK_IMAGES = {
  heroAtmosphere: {
    filename: '015.a8Stock.GRAPHIC-ELEMENTS.jpg',
    src: 'https://pub-906aebdaaf22471faa576c94c2cdf07b.r2.dev/015.a8Stock.GRAPHIC-ELEMENTS.jpg',
  },
  workflowSystems: {
    filename: '009.a8Stock.SYSTEMS.jpg',
    src: 'https://pub-906aebdaaf22471faa576c94c2cdf07b.r2.dev/009.a8Stock.SYSTEMS.jpg',
  },
  processSystems: {
    filename: '007.a8Stock.SYSTEMS.jpg',
    src: 'https://pub-906aebdaaf22471faa576c94c2cdf07b.r2.dev/007.a8Stock.SYSTEMS.jpg',
  },
  partnershipTeams: {
    filename: '013.a8Stock.TEAMS.jpg',
    src: 'https://pub-906aebdaaf22471faa576c94c2cdf07b.r2.dev/013.a8Stock.TEAMS.jpg',
  },
  revenueOutcomes: {
    filename: '006.a8Stock.REVENUE.jpg',
    src: 'https://pub-906aebdaaf22471faa576c94c2cdf07b.r2.dev/006.a8Stock.REVENUE.jpg',
  },
  insightsDataViz: {
    filename: '004.a8Stock.DATA-VIZ.jpg',
    src: 'https://pub-906aebdaaf22471faa576c94c2cdf07b.r2.dev/004.a8Stock.DATA-VIZ.jpg',
  },
  closingTexture: {
    filename: '017.a8Stock.GRAPHIC-ELEMENTS.jpg',
    src: 'https://pub-906aebdaaf22471faa576c94c2cdf07b.r2.dev/017.a8Stock.GRAPHIC-ELEMENTS.jpg',
  },
} as const;

const copy = landingCopy.values as Record<string, string>;

const processSteps = [
  {
    number: '1',
    title: copy['how.identify.title'],
    body: copy['how.identify.body'],
  },
  {
    number: '2',
    title: copy['how.recommend.title'],
    body: copy['how.recommend.body'],
  },
  {
    number: '3',
    title: copy['how.connect.title'],
    body: copy['how.connect.body'],
  },
] as const;

const problemCards = [
  {
    number: '1',
    title: copy['problems.invoice.title'],
    body: copy['problems.invoice.body'],
  },
  {
    number: '2',
    title: copy['problems.sales.title'],
    body: copy['problems.sales.body'],
  },
  {
    number: '3',
    title: copy['problems.ar.title'],
    body: copy['problems.ar.body'],
  },
  {
    number: '4',
    title: copy['problems.scale.title'],
    body: copy['problems.scale.body'],
  },
] as const;

const whyCards = [
  {
    number: '1',
    title: copy['why.revenue.title'],
    body: copy['why.revenue.body'],
  },
  {
    number: '2',
    title: copy['why.opinion.title'],
    body: copy['why.opinion.body'],
  },
  {
    number: '3',
    title: copy['why.experts.title'],
    body: copy['why.experts.body'],
  },
] as const;
---

<Base title={copy['page.title']} description={copy['meta.description']}>
  <nav class="navbar">
      <div class="navbar-container">
        <div class="navbar-logo">
          <img src="/assets/logos/v2_Acceler8_Logo_Company.png" alt="Acceler8-ai" class="navbar-logo-img">
        </div>
      <ul class="nav-menu">
        <li><a href="#contact">{copy['nav.contact']}</a></li>
      </ul>
      <button class="nav-cta" onclick="window.location.href='mailto:connect@acceler8-ai.com'">{copy['cta.header']}</button>
    </div>
  </nav>

  <section class="hero visual-section visual-section--hero">
    <img class="visual-section__media" src={STOCK_IMAGES.heroAtmosphere.src} alt="" aria-hidden="true" loading="eager" decoding="async">
    <div class="visual-section__overlay visual-section__overlay--hero"></div>
    <div class="hero-container">
      <div class="hero-content scroll-fade-in">
        <h1 class="hero-headline">{copy['hero.headline']}</h1>
        <p class="hero-subtitle">{copy['hero.subtitle']}</p>
        <div class="hero-buttons">
          <button class="btn btn-primary" onclick="window.location.href='mailto:connect@acceler8-ai.com'">{copy['cta.hero_primary']}</button>
          <button class="btn btn-secondary" onclick="scrollToSection('how-we-work')">{copy['cta.hero_secondary']}</button>
        </div>
      </div>
      <div class="hero-visual scroll-fade-in">
        <div class="workflow-panel hero-panel">
          <div class="hero-panel-grid">
            {processSteps.map((step) => (
              <div class="panel-card">
                <div class="service-number">{step.number}</div>
                <h3>{step.title}</h3>
                <p>{step.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="problems" class="problem-section visual-section visual-section--dark scroll-fade-in">
    <img class="visual-section__media" src={STOCK_IMAGES.workflowSystems.src} alt="" aria-hidden="true" loading="lazy" decoding="async">
    <div class="visual-section__overlay visual-section__overlay--dark"></div>
    <div class="container">
      <div class="section-intro">
        <h2 class="section-title">{copy['problems.heading']}</h2>
      </div>
      <div class="cards-grid stagger-children">
        {problemCards.map((card) => (
          <div class="card">
            <div class="service-number">{card.number}</div>
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="how-we-work" class="services-section visual-section visual-section--light scroll-fade-in">
    <img class="visual-section__media" src={STOCK_IMAGES.processSystems.src} alt="" aria-hidden="true" loading="lazy" decoding="async">
    <div class="visual-section__overlay visual-section__overlay--light"></div>
    <div class="container">
      <div class="section-intro section-intro--dark">
        <h2 class="section-title">{copy['how.heading']}</h2>
      </div>
      <div class="cards-grid cards-3col stagger-children">
        {processSteps.map((step) => (
          <div class="card card-service">
            <div class="service-number">{step.number}</div>
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="network" class="network-section visual-section visual-section--teal scroll-fade-in">
    <img class="visual-section__media" src={STOCK_IMAGES.partnershipTeams.src} alt="" aria-hidden="true" loading="lazy" decoding="async">
    <div class="visual-section__overlay visual-section__overlay--teal"></div>
    <div class="container">
      <div class="section-intro">
        <h2 class="section-title">{copy['network.heading']}</h2>
        <p class="section-subtitle">{copy['network.subtitle']}</p>
      </div>
    </div>
  </section>

  <section class="why-section visual-section visual-section--warm scroll-fade-in">
    <img class="visual-section__media" src={STOCK_IMAGES.revenueOutcomes.src} alt="" aria-hidden="true" loading="lazy" decoding="async">
    <div class="visual-section__overlay visual-section__overlay--warm"></div>
    <div class="container">
      <div class="section-intro">
        <h2 class="section-title">{copy['why.heading']}</h2>
      </div>
      <div class="cards-grid stagger-children">
        {whyCards.map((card) => (
          <div class="card">
            <div class="service-number">{card.number}</div>
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="insights" class="positioning-strip visual-section visual-section--navy scroll-fade-in">
    <img class="visual-section__media" src={STOCK_IMAGES.insightsDataViz.src} alt="" aria-hidden="true" loading="lazy" decoding="async">
    <div class="visual-section__overlay visual-section__overlay--navy"></div>
    <div class="container">
      <div class="section-intro section-intro--light">
        <p class="positioning-text">{copy['positioning.strip']}</p>
      </div>
    </div>
  </section>

  <section class="closing-cta visual-section visual-section--cta scroll-fade-in">
    <img class="visual-section__media" src={STOCK_IMAGES.closingTexture.src} alt="" aria-hidden="true" loading="lazy" decoding="async">
    <div class="visual-section__overlay visual-section__overlay--cta"></div>
    <div class="container">
      <div class="cta-panel">
        <h2 class="section-title">{copy['closing.heading']}</h2>
        <button class="btn btn-primary btn-large" onclick="window.location.href='mailto:connect@acceler8-ai.com'">{copy['cta.closing']}</button>
      </div>
    </div>
  </section>

  <footer id="contact" class="footer">
    <div class="footer-container">
      <div class="footer-section">
        <h3>{copy['footer.brand_heading']}</h3>
        <p>{copy['footer.description']}</p>
      </div>
      <div class="footer-section footer-contact">
        <p><a href="mailto:connect@acceler8-ai.com">{copy['footer.email']}</a></p>
        <p><a href="tel:206-970-6240">{copy['footer.phone']}</a></p>
      </div>
    </div>
    <div class="footer-bottom">
      <p>{copy['footer.copyright']}</p>
    </div>
  </footer>

  <style>
    .positioning-strip {
      background-color: var(--color-acceler8-red);
      color: var(--text-light);
      padding: 2rem 0;
    }

    .positioning-text {
      text-align: center;
      font-size: clamp(1.25rem, 2vw, 1.55rem);
      font-weight: 700;
      margin: 0;
      line-height: 1.5;
      color: var(--text-light);
      font-family: var(--font-family-base);
      letter-spacing: -0.01em;
    }

    .closing-cta {
      text-align: center;
      padding: 2.5rem 0;
    }

    .closing-cta .btn {
      margin-top: var(--space-xl);
    }

    .problem-section,
    .services-section,
    .network-section,
    .why-section,
    .closing-cta {
      background-color: #FFFFFF;
    }

    .hero {
      padding: 5rem 0;
      background-color: #FFFFFF;
      position: relative;
      overflow: hidden;
    }

    .hero.visual-section--hero {
      min-height: 600px;
      display: flex;
      align-items: center;
    }

    .hero-container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 var(--space-lg);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
      position: relative;
      z-index: 3;
      width: 100%;
    }

    .hero-content {
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .hero-headline {
      color: var(--text-primary);
      margin-bottom: var(--space-lg);
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 700;
      line-height: 1.2;
    }

    .hero-subtitle {
      font-size: 1.1rem;
      color: var(--text-secondary);
      margin-bottom: var(--space-2xl);
      line-height: 1.8;
    }

    .hero-visual {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .workflow-panel {
      background: linear-gradient(135deg, rgba(37, 99, 235, 0.05) 0%, rgba(47, 125, 122, 0.05) 100%);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-xl);
      padding: 2.5rem;
      box-shadow: var(--shadow-md);
      width: 100%;
    }

    .hero-panel-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }

    .panel-card {
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: var(--radius-lg);
      padding: 1.25rem;
      box-shadow: var(--shadow-sm);
    }

    .panel-card h3 {
      margin: 0.75rem 0 0.5rem;
      color: var(--text-primary);
    }

    .panel-card p {
      margin: 0;
      color: var(--text-secondary);
      line-height: 1.65;
    }

    .flow-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .flow-step {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-sm);
      flex: 1;
      min-width: 100px;
    }

    .flow-icon {
      font-size: 2.5rem;
      display: block;
    }

    .flow-label {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--text-primary);
      margin: 0;
      text-align: center;
    }

    .flow-arrow {
      color: var(--accent-secondary);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .flow-arrow svg {
      stroke: var(--accent-secondary);
    }

    @media (max-width: 1024px) {
      .hero-container {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      .workflow-panel {
        padding: 1.5rem;
      }

      .hero-panel-grid {
        grid-template-columns: 1fr;
      }

      .flow-row {
        gap: 0.5rem;
      }

      .flow-step {
        min-width: 80px;
      }

      .flow-icon {
        font-size: 2rem;
      }

      .flow-label {
        font-size: 0.75rem;
      }
    }

    @media (max-width: 640px) {
      .hero {
        padding: 3rem 0;
      }

      .hero-headline {
        font-size: 1.75rem;
      }

      .hero-subtitle {
        font-size: 1rem;
      }

      .flow-row {
        flex-direction: column;
        gap: 1rem;
      }

      .flow-step {
        min-width: 100%;
      }

      .flow-arrow {
        transform: rotate(90deg);
      }

      .workflow-panel {
        padding: 1rem;
      }
    }

    .visual-section {
      position: relative;
      overflow: hidden;
    }

    .visual-section__media {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      z-index: 0;
    }

    .visual-section__overlay {
      position: absolute;
      inset: 0;
      z-index: 1;
    }

    .visual-section__overlay--hero {
      background: linear-gradient(90deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.82) 52%, rgba(255, 255, 255, 0.15) 100%);
    }

    .visual-section__overlay--dark {
      background: linear-gradient(135deg, rgba(7, 15, 28, 0.78) 0%, rgba(7, 15, 28, 0.62) 100%);
    }

    .visual-section__overlay--light {
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.72) 0%, rgba(255, 255, 255, 0.54) 100%);
    }

    .visual-section__overlay--teal {
      background: linear-gradient(135deg, rgba(10, 72, 76, 0.78) 0%, rgba(10, 72, 76, 0.58) 100%);
    }

    .visual-section__overlay--warm {
      background: linear-gradient(135deg, rgba(97, 40, 21, 0.78) 0%, rgba(97, 40, 21, 0.56) 100%);
    }

    .visual-section__overlay--navy {
      background: linear-gradient(135deg, rgba(6, 32, 68, 0.78) 0%, rgba(6, 32, 68, 0.56) 100%);
    }

    .visual-section__overlay--cta {
      background: linear-gradient(135deg, rgba(94, 44, 17, 0.84) 0%, rgba(94, 44, 17, 0.6) 100%);
    }

    .visual-section > .container,
    .hero-container {
      position: relative;
      z-index: 2;
    }

    .section-intro {
      margin-bottom: var(--space-2xl);
    }

    .section-intro .section-title {
      margin-top: 0;
      margin-bottom: var(--space-md);
    }

    .section-intro .section-subtitle {
      margin-bottom: 0;
    }

    .section-intro--dark .section-title,
    .section-intro--dark .section-subtitle {
      color: var(--text-primary);
    }

    .section-intro--light .section-title,
    .section-intro--light .section-subtitle {
      color: var(--text-light);
    }

    .section-title {
      margin-top: 0;
    }

    .cards-grid {
      display: grid;
      gap: var(--space-lg);
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }

    .cards-3col {
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }

    .card {
      background: rgba(255, 255, 255, 0.9);
      border: 1px solid rgba(15, 23, 42, 0.1);
      border-radius: var(--radius-xl);
      padding: 1.5rem;
      box-shadow: var(--shadow-sm);
    }

    .card h3 {
      margin: 0.75rem 0 0.5rem;
      color: var(--text-primary);
    }

    .card p {
      margin: 0;
      line-height: 1.7;
      color: var(--text-secondary);
    }

    .service-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2.25rem;
      height: 2.25rem;
      border-radius: 999px;
      background: rgba(215, 25, 32, 0.12);
      color: var(--color-acceler8-red);
      font-weight: 700;
      font-size: 0.95rem;
    }

    .cta-panel {
      max-width: 48rem;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .footer {
      background: #fff;
    }

    @media (max-width: 1024px) {
      .hero-container {
        grid-template-columns: 1fr;
      }

      .cards-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    const scrollToSection = (id: string): void => {
      const element = document.getElementById(id);
      if (element) {
        element.scrollIntoView({ behavior: 'smooth' });
      }
    };

    window.scrollToSection = scrollToSection;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px',
    });

    document.querySelectorAll('.scroll-fade-in, .scroll-slide-left, .scroll-slide-right').forEach((el) => {
      observer.observe(el);
    });

    document.querySelectorAll('.stagger-children').forEach((container) => {
      container.querySelectorAll(':scope > *').forEach((child, index) => {
        if (child instanceof HTMLElement) {
          child.style.animation = `fadeInUp 0.6s ease-out ${index * 0.1 + 0.2}s backwards`;
        }
      });
    });
  </script>
</Base>
