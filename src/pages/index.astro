---
import Base from '../layouts/Base.astro';
import { landingCopy } from '../data/a8LandingCopy';

const copy = landingCopy.values as Record<string, string>;
const assets = landingCopy.graphicAssets as Record<string, string>;

const processSteps = [
  { number: '1', title: copy['how.identify.title'], body: copy['how.identify.body'] },
  { number: '2', title: copy['how.recommend.title'], body: copy['how.recommend.body'] },
  { number: '3', title: copy['how.connect.title'], body: copy['how.connect.body'] },
] as const;

const problemCards = [
  { number: '1', title: copy['problems.invoice.title'], body: copy['problems.invoice.body'] },
  { number: '2', title: copy['problems.sales.title'], body: copy['problems.sales.body'] },
  { number: '3', title: copy['problems.ar.title'], body: copy['problems.ar.body'] },
  { number: '4', title: copy['problems.scale.title'], body: copy['problems.scale.body'] },
] as const;

const whyCards = [
  { number: '1', title: copy['why.revenue.title'], body: copy['why.revenue.body'] },
  { number: '2', title: copy['why.opinion.title'], body: copy['why.opinion.body'] },
  { number: '3', title: copy['why.experts.title'], body: copy['why.experts.body'] },
] as const;

const images = {
  hero: {
    src: assets['a8_HeroImage'],
    alt: 'Black and white wildebeest river crossing landscape photograph.',
  },
  problems: {
    src: 'https://pub-906aebdaaf22471faa576c94c2cdf07b.r2.dev/024.a8Stock.GRAPHIC-ELEMENTS.jpg',
    alt: 'Abstract workflow graphic with intersecting blue lines and panels.',
  },
  process: {
    src: 'https://pub-906aebdaaf22471faa576c94c2cdf07b.r2.dev/027.a8Stock.GRAPHIC-ELEMENTS.jpg',
    alt: 'Abstract structured blue graphic elements suggesting connected systems.',
  },
  network: {
    src: 'https://pub-906aebdaaf22471faa576c94c2cdf07b.r2.dev/030.a8Stock.GRAPHIC-ELEMENTS.jpg',
    alt: 'Abstract blue and cyan grid graphic suggesting connected providers.',
  },
  why: {
    src: 'https://pub-906aebdaaf22471faa576c94c2cdf07b.r2.dev/033.a8Stock.GRAPHIC-ELEMENTS.jpg',
    alt: 'Abstract blue workflow graphic with layered planes and signal lines.',
  },
  closing: {
    src: 'https://pub-906aebdaaf22471faa576c94c2cdf07b.r2.dev/034.a8Stock.GRAPHIC-ELEMENTS.jpg',
    alt: 'Abstract navy and blue graphic elements with soft geometric shapes.',
  },
} as const;
---

<Base title={copy['page.title']} description={copy['meta.description']}>
  <nav class="topbar" aria-label="Primary">
    <div class="topbar__inner">
      <a href="/" class="topbar__logo">
        <img
          src={assets['a8_LogoOnTransp']}
          alt="Acceler8-ai logo"
          class="rounded-lg"
          style={{ maxWidth: '270px', maxHeight: '360px', width: 'auto', height: 'auto', display: 'block' }}
        />
      </a>
      <div class="topbar__actions">
        <a class="topbar__link" href="#contact">{copy['nav.contact']}</a>
        <a class="btn btn-primary" href={`mailto:${copy['footer.email']}`}>{copy['cta.header']}</a>
      </div>
    </div>
  </nav>

  <main id="top" class="page-shell">
    <section class="hero section section--hero">
      <div class="container hero__grid">
        <div class="hero__copy">
          <p class="hero__eyebrow">Acceler8-ai</p>
          <h1>{copy['hero.headline']}</h1>
          <p class="hero__subtitle">{copy['hero.subtitle']}</p>
          <div class="hero__actions">
            <a class="btn btn-primary" href={`mailto:${copy['footer.email']}`}>{copy['cta.hero_primary']}</a>
            <a class="btn btn-secondary" href="#how-we-work">{copy['cta.hero_secondary']}</a>
          </div>
          <div class="hero__signal">{copy['positioning.strip']}</div>
        </div>

        <div class="hero__panel card">
          <div class="workflow-header">
            <p class="workflow-header__label">{copy['problems.heading']}</p>
            <h2>{copy['how.heading']}</h2>
          </div>
          <div class="workflow-map" aria-label="Workflow path from bottleneck to implementation">
            <div class="workflow-map__row workflow-map__row--problems">
              {problemCards.map((card, index) => (
                <article class="workflow-node workflow-node--problem">
                  <span class="workflow-node__index">{String(index + 1).padStart(2, '0')}</span>
                  <h3>{card.title}</h3>
                  <p>{card.body}</p>
                </article>
              ))}
            </div>
            <div class="workflow-bridge">
              <span class="workflow-bridge__line" aria-hidden="true"></span>
              <span class="workflow-bridge__label">Acceler8-ai</span>
              <span class="workflow-bridge__line" aria-hidden="true"></span>
            </div>
            <div class="workflow-map__row workflow-map__row--steps">
              {processSteps.map((step) => (
                <article class="workflow-node workflow-node--step">
                  <span class="workflow-node__index">{step.number}</span>
                  <h3>{step.title}</h3>
                  <p>{step.body}</p>
                </article>
              ))}
            </div>
          </div>
          <div class="hero__images">
            <figure class="image-tile"><img src={images.hero.src} alt={images.hero.alt} loading="eager" decoding="async" /></figure>
            <figure class="image-tile"><img src={images.problems.src} alt={images.problems.alt} loading="eager" decoding="async" /></figure>
            <figure class="image-tile"><img src={images.process.src} alt={images.process.alt} loading="eager" decoding="async" /></figure>
            <figure class="image-tile"><img src={images.network.src} alt={images.network.alt} loading="eager" decoding="async" /></figure>
          </div>
        </div>
      </div>
    </section>

    <section class="section section--subtle" id="problems">
      <div class="container section__grid">
        <div class="section__heading">
          <h2>{copy['problems.heading']}</h2>
          <p>{copy['meta.description']}</p>
        </div>
        <div class="cards-grid cards-grid--four">
          {problemCards.map((card) => (
            <article class="card workflow-card">
              <span class="workflow-node__index">{card.number.padStart(2, '0')}</span>
              <h3>{card.title}</h3>
              <p>{card.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--white" id="how-we-work">
      <div class="container section__grid section__grid--split">
        <div class="section__stack">
          <div class="section__heading">
            <h2>{copy['how.heading']}</h2>
            <p>{copy['network.subtitle']}</p>
          </div>
          <div class="steps">
            {processSteps.map((step) => (
              <article class="card step-card">
                <span class="workflow-node__index">{step.number.padStart(2, '0')}</span>
                <h3>{step.title}</h3>
                <p>{step.body}</p>
              </article>
            ))}
          </div>
        </div>
        <div class="image-stack">
          <figure class="media-card"><img src={images.process.src} alt={images.process.alt} loading="lazy" decoding="async" /></figure>
          <figure class="media-card"><img src={images.network.src} alt={images.network.alt} loading="lazy" decoding="async" /></figure>
          <figure class="media-card"><img src={images.why.src} alt={images.why.alt} loading="lazy" decoding="async" /></figure>
          <div class="callout card"><p>{copy['positioning.strip']}</p></div>
        </div>
      </div>
    </section>

    <section class="section section--subtle" id="network">
      <div class="container section__grid">
        <div class="section__heading">
          <h2>{copy['network.heading']}</h2>
          <p>{copy['network.subtitle']}</p>
        </div>
        <div class="image-rail">
          <figure class="media-card media-card--rail"><img src={images.hero.src} alt={images.hero.alt} loading="lazy" decoding="async" /></figure>
          <figure class="media-card media-card--rail"><img src={images.process.src} alt={images.process.alt} loading="lazy" decoding="async" /></figure>
          <figure class="media-card media-card--rail"><img src={images.network.src} alt={images.network.alt} loading="lazy" decoding="async" /></figure>
          <figure class="media-card media-card--rail"><img src={images.closing.src} alt={images.closing.alt} loading="lazy" decoding="async" /></figure>
        </div>
        <div class="network-note card">
          <p>{copy['how.connect.body']}</p>
        </div>
      </div>
    </section>

    <section class="section section--white" id="why">
      <div class="container section__grid">
        <div class="section__heading">
          <h2>{copy['why.heading']}</h2>
        </div>
        <div class="cards-grid cards-grid--three">
          {whyCards.map((card) => (
            <article class="card why-card">
              <span class="workflow-node__index">{card.number.padStart(2, '0')}</span>
              <h3>{card.title}</h3>
              <p>{card.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--closing">
      <div class="container closing">
        <div class="closing__copy">
          <h2>{copy['closing.heading']}</h2>
          <p>{copy['footer.description']}</p>
          <a class="btn btn-primary btn-large" href={`mailto:${copy['footer.email']}`}>{copy['cta.closing']}</a>
        </div>
        <div class="closing__images">
          <figure class="media-card media-card--closing"><img src={images.closing.src} alt={images.closing.alt} loading="lazy" decoding="async" /></figure>
          <figure class="media-card media-card--closing"><img src={images.why.src} alt={images.why.alt} loading="lazy" decoding="async" /></figure>
          <figure class="media-card media-card--closing"><img src={images.network.src} alt={images.network.alt} loading="lazy" decoding="async" /></figure>
        </div>
      </div>
    </section>

    <footer id="contact" class="footer">
      <div class="container footer__grid">
        <div class="footer__brand">
          <h3>{copy['footer.brand_heading']}</h3>
          <p>{copy['footer.description']}</p>
        </div>
        <div class="footer__contact">
          <a href={`mailto:${copy['footer.email']}`}>{copy['footer.email']}</a>
          <a href={`tel:${copy['footer.phone']}`}>{copy['footer.phone']}</a>
        </div>
      </div>
      <div class="container footer__bottom">
        <p>{copy['footer.copyright']}</p>
      </div>
    </footer>
  </main>
</Base>

<style>
  .page-shell {
    background:
      radial-gradient(circle at top left, rgba(29, 78, 216, 0.08), transparent 30%),
      radial-gradient(circle at 90% 8%, rgba(14, 116, 144, 0.06), transparent 28%),
      var(--bg-page);
  }

  .topbar {
    position: sticky;
    top: 0;
    z-index: 40;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border-default);
  }

  .topbar__inner,
  .footer__grid,
  .footer__bottom {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  .topbar__inner {
    min-height: 4.75rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .brand {
    color: var(--text-primary);
    text-decoration: none;
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .topbar__logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .topbar__logo img {
    max-width: 270px;
    max-height: 360px;
    width: auto;
    height: auto;
  }

  .topbar__actions {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .topbar__link {
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 600;
  }

  .section {
    padding: clamp(3.75rem, 7vw, 6.25rem) 0;
  }

  .section--hero {
    padding-top: clamp(2rem, 4vw, 3rem);
  }

  .section--subtle {
    background: var(--bg-subtle);
  }

  .section--closing {
    background:
      linear-gradient(135deg, rgba(15, 23, 42, 0.98), rgba(30, 58, 138, 0.95)),
      var(--bg-dark);
    color: var(--text-light);
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  .hero__grid,
  .section__grid,
  .closing {
    display: grid;
    gap: var(--space-xl);
  }

  .hero__grid {
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    align-items: start;
  }

  .hero__copy {
    padding-top: clamp(1rem, 3vw, 3rem);
  }

  .hero__eyebrow {
    margin: 0 0 var(--space-sm);
    color: var(--color-acceler8-blue-dark);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero__copy h1 {
    margin: 0;
    max-width: 13ch;
  }

  .hero__subtitle {
    margin: var(--space-md) 0 0;
    max-width: 34rem;
    font-size: clamp(1.125rem, 2vw, 1.35rem);
    line-height: 1.55;
    color: var(--text-secondary);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
  }

  .hero__signal {
    margin-top: var(--space-lg);
    max-width: 28rem;
    padding: 1rem 1.15rem;
    border-left: 3px solid var(--border-blue);
    background: var(--bg-subtle);
    color: var(--text-secondary);
    border-radius: 0.5rem;
  }

  .hero__panel {
    display: grid;
    gap: var(--space-lg);
  }

  .workflow-header__label,
  .workflow-node__index {
    font-family: var(--font-mono);
  }

  .workflow-header__label {
    margin: 0 0 var(--space-xs);
    color: var(--color-acceler8-blue-dark);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .workflow-header h2 {
    margin: 0;
  }

  .workflow-map {
    display: grid;
    gap: var(--space-md);
  }

  .workflow-map__row {
    display: grid;
    gap: var(--space-sm);
  }

  .workflow-map__row--problems,
  .workflow-map__row--steps {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .workflow-node {
    padding: 1rem 1rem 1.1rem;
    border: 1px solid var(--border-default);
    border-radius: 0.9rem;
    background: var(--bg-card);
    box-shadow: var(--shadow-sm);
  }

  .workflow-node--step {
    border-color: var(--border-blue);
    background: var(--bg-blue-subtle);
  }

  .workflow-node h3,
  .workflow-node p,
  .workflow-node__index {
    margin: 0;
  }

  .workflow-node h3 {
    margin-top: var(--space-xs);
    margin-bottom: var(--space-xs);
  }

  .workflow-node p {
    color: var(--text-secondary);
  }

  .workflow-bridge {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-sm);
  }

  .workflow-bridge__line {
    height: 1px;
    background: var(--border-default);
  }

  .workflow-bridge__label {
    color: var(--color-acceler8-blue);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero__images,
  .image-stack,
  .image-rail,
  .closing__images {
    display: grid;
    gap: var(--space-sm);
  }

  .hero__images {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .image-stack {
    align-content: start;
  }

  .image-rail {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .closing__images {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .image-tile,
  .media-card {
    margin: 0;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid var(--border-default);
    background: var(--bg-card);
    box-shadow: var(--shadow-sm);
  }

  .image-tile img,
  .media-card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-tile {
    min-height: 8.5rem;
  }

  .media-card--rail {
    min-height: 6.5rem;
  }

  .media-card--closing {
    min-height: 7.5rem;
  }

  .section__grid {
    grid-template-columns: minmax(0, 1fr);
  }

  .section__grid--split {
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.9fr);
  }

  .section__heading h2 {
    margin-top: 0;
  }

  .section__heading p {
    margin: 0;
    max-width: 46rem;
    color: var(--text-secondary);
  }

  .section__stack {
    display: grid;
    gap: var(--space-lg);
  }

  .steps,
  .cards-grid {
    display: grid;
    gap: var(--space-lg);
  }

  .steps {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .cards-grid--four {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .cards-grid--three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .workflow-node__index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.25rem;
    height: 2.25rem;
    border-radius: 999px;
    background: var(--bg-blue-subtle);
    color: var(--color-acceler8-blue);
    border: 1px solid var(--border-blue);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .card {
    border-radius: 1rem;
    border: 1px solid var(--border-default);
    box-shadow: var(--shadow-sm);
    background: var(--bg-card);
  }

  .card h3 {
    margin-top: var(--space-sm);
  }

  .card p {
    margin-bottom: 0;
  }

  .callout {
    padding: 1.25rem 1.25rem 1.4rem;
  }

  .callout p,
  .network-note p,
  .closing__copy p,
  .footer__brand p {
    color: inherit;
  }

  .network-note {
    max-width: 54rem;
  }

  .closing {
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    align-items: center;
    color: var(--text-light);
  }

  .closing__copy h2,
  .closing__copy p {
    color: inherit;
  }

  .closing__copy {
    display: grid;
    gap: var(--space-md);
    max-width: 34rem;
  }

  .closing__images {
    align-items: stretch;
  }

  .footer {
    background: var(--bg-dark);
    color: var(--text-light);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: var(--space-lg);
    padding-top: var(--space-xl);
  }

  .footer__brand h3 {
    margin-top: 0;
  }

  .footer__brand p,
  .footer__contact a,
  .footer__bottom p {
    color: rgba(255, 255, 255, 0.78);
  }

  .footer__contact {
    display: grid;
    align-content: start;
    gap: var(--space-sm);
  }

  .footer__contact a {
    text-decoration: none;
    font-weight: 700;
  }

  .footer__bottom {
    padding-top: var(--space-lg);
    padding-bottom: var(--space-xl);
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  @media (max-width: 1024px) {
    .hero__grid,
    .section__grid--split,
    .closing,
    .footer__grid {
      grid-template-columns: 1fr;
    }

    .steps,
    .cards-grid--four,
    .cards-grid--three,
    .image-rail,
    .closing__images,
    .hero__images,
    .workflow-map__row--problems,
    .workflow-map__row--steps {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 720px) {
    .topbar__inner,
    .topbar__actions {
      flex-direction: column;
      align-items: stretch;
    }

    .topbar__actions,
    .hero__actions,
    .hero__images,
    .steps,
    .cards-grid--four,
    .cards-grid--three,
    .image-rail,
    .closing__images,
    .workflow-map__row--problems,
    .workflow-map__row--steps {
      grid-template-columns: 1fr;
    }

    .btn,
    .topbar__actions .btn {
      width: 100%;
    }
  }
</style>
